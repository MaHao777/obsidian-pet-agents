{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "lib": [
      "DOM",
      "ES2021"
    ],
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "allowJs": false,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*.ts"
  ]
}
